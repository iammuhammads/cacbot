    "fastify": "^5.2.1",
    "imapflow": "^1.0.181",
    "mailparser": "^3.7.2",
    "openai": "^4.87.3",
    "playwright": "^1.51.1",
    "redis": "^4.7.0",
    "twilio": "^5.13.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
